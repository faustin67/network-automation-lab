{# frr_ospf.j2 — FRR ospfd configuration for routers running OSPF #}
! ============================================================
! FRR OSPF Configuration — {{ hostname }}
! Router-ID: {{ ospf.router_id }}
! Generated by Ansible — do not edit manually
! ============================================================

frr version 9.0
frr defaults traditional
hostname {{ hostname }}
log syslog informational
service integrated-vtysh-config
!
! --- IP Forwarding ---
ip forwarding
!
! --- Interface definitions ---
{% for iface, cfg in ospf.interfaces.items() %}
interface {{ iface }}
{% if cfg.passive %}
 description OSPF passive — {{ iface }}
{% else %}
 description OSPF active — {{ iface }}
 ip ospf hello-interval {{ ospf_hello_interval | default(10) }}
 ip ospf dead-interval {{ ospf_dead_interval | default(40) }}
 ip ospf cost {{ cfg.cost }}
 ip ospf network point-to-point
{% endif %}
!
{% endfor %}
!
! --- OSPF Process ---
router ospf
 ospf router-id {{ ospf.router_id }}
 auto-cost reference-bandwidth {{ ospf_reference_bandwidth | default(100) }}
!
{% for iface, cfg in ospf.interfaces.items() %}
{% if cfg.passive %}
 passive-interface {{ iface }}
{% endif %}
 network {{ cfg.network }} area {{ ospf.area }}
{% endfor %}
!
line vty
!

