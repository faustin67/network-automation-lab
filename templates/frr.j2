{# frr.j2 — Combined FRR configuration for all routers
   Writes to /etc/frr/frr.conf (integrated config mode)
   Targets: A-RTR1, A-RTR2, A-RTR3, B-RTR1
#}
! ============================================================
! FRR Integrated Configuration — {{ hostname }}
! Role: {{ device_role }}
! Generated by Ansible — do not edit manually
! ============================================================

frr version 8.4.4
frr defaults traditional
hostname {{ hostname }}
log syslog informational
no ipv6 forwarding
service integrated-vtysh-config
!
! ============================================================
! SECTION 1 — Interface Definitions
! ============================================================
{% for iface, cfg in ospf.interfaces.items() %}
interface {{ iface }}
{% if cfg.passive %}
 description Passive — {{ iface }} — OSPF advertised, no hellos
{% else %}
 description Active — {{ iface }} — OSPF {{ cfg.network_type | default('point-to-point') }}
 ip ospf hello-interval {{ ospf_hello_interval | default(10) }}
 ip ospf dead-interval {{ ospf_dead_interval | default(40) }}
 ip ospf cost {{ cfg.cost }}
 ip ospf network {{ cfg.network_type | default('point-to-point') }}
{% endif %}
!
{% endfor %}
!
! ============================================================
! SECTION 2 — OSPF Configuration
! ============================================================
router ospf
 ospf router-id {{ ospf.router_id }}
 auto-cost reference-bandwidth {{ ospf_reference_bandwidth | default(100) }}
!
{% for iface, cfg in ospf.interfaces.items() %}
{% if cfg.passive %}
 passive-interface {{ iface }}
{% endif %}
 network {{ cfg.network }} area {{ ospf.area }}
{% endfor %}
!
! ============================================================
! SECTION 3 — VRRP Configuration
! ============================================================
{% if vrrp is defined %}
{% for v in vrrp %}
interface {{ v.interface }}
 vrrp {{ v.group }} ip {{ v.virtual_ip }}
 vrrp {{ v.group }} priority {{ v.priority }}
 vrrp {{ v.group }} advertisement-interval {{ v.advert_interval }}
{% if v.preempt %}
 vrrp {{ v.group }} preempt
{% endif %}
!
{% endfor %}
{% else %}
! No VRRP configured on {{ hostname }}
{% endif %}
!
line vty
!
