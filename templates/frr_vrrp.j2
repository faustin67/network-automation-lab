{# frr_vrrp.j2 — FRR VRRP configuration — Campus A routers only (A-RTR1, A-RTR2) #}
! ============================================================
! FRR VRRP Configuration — {{ hostname }}
! Generated by Ansible — do not edit manually
! ============================================================
{% if vrrp is defined %}
{% for v in vrrp %}
!
interface {{ v.interface }}
 vrrp {{ v.group }} ip {{ v.virtual_ip }}
 vrrp {{ v.group }} priority {{ v.priority }}
 vrrp {{ v.group }} advertisement-interval {{ v.advert_interval }}
{% if v.preempt %}
 vrrp {{ v.group }} preempt
{% endif %}
!
{% endfor %}
{% else %}
! No VRRP configured on {{ hostname }}
{% endif %}

